# Copy to .env and fill in real values (gitignored)

# Clerk issuer URL — find under Dashboard → API Keys → Advanced → JWT public key
# Example: https://example-app-1234.clerk.accounts.dev
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# Comma-separated list of allowed `azp` claim values (the origins that requested the token).
# Must include every web origin you use during dev.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Server config
API_PORT=8080
RUST_LOG=info,api=debug
